# OpenAI API key (required for OpenAI models)
OPENAI_API_KEY=

# Anthropic API key (required for Claude models)
ANTHROPIC_API_KEY=

# Google AI Studio API key (required for Gemini models)
GOOGLE_API_KEY=

# Ollama base URL (optional, defaults to http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Path to the webapp's server data directory (where questions.json is written)
# Defaults to ../llmeter/src/lib/server
WEBAPP_DATA_PATH=../llmeter/src/lib/server

# Path to the webapp's static images directory (where model logos are saved)
# Defaults to ../llmeter/static/images/models
WEBAPP_IMAGES_PATH=../llmeter/static/images/models
